{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "start": "cross-env EXPO_OFFLINE=1 EXPO_NO_TELEMETRY=1 expo start",
    "start:clear": "cross-env EXPO_OFFLINE=1 EXPO_NO_TELEMETRY=1 expo start --clear",
    "start:online": "expo start",
    "android": "cross-env EXPO_OFFLINE=1 EXPO_NO_TELEMETRY=1 expo start --android",
    "ios": "cross-env EXPO_OFFLINE=1 EXPO_NO_TELEMETRY=1 expo start --ios",
    "web": "cross-env EXPO_OFFLINE=1 EXPO_NO_TELEMETRY=1 expo start --web",
    "build:web": "expo export --platform web --output-dir web-build",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=moderate"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "expo": "~54.0.35",
    "expo-linear-gradient": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.553.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "^0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.11",
    "cross-env": "^7.0.3",
    "typescript": "~5.9.2"
  }
