{
  "name": "ai-worker",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "dev:prod-env": "cross-env ENV_FILE=production ts-node -r tsconfig-paths/register src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.84",
    "@ai-sdk/openai": "^3.0.75",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.211",
    "bullmq": "^5.79.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "typescript": "^6.0.3"
  }
}
