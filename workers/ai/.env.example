REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379
AI_CHAT_QUEUE=ai-chat
AI_CHAT_WORKER_CONCURRENCY=2

# Provider options. The worker uses the first configured provider in this order:
# GEMINI_API_KEY, DEEP_SEEK_AI_API_KEY, OPENAI_API_KEY.
GEMINI_API_KEY=
GEMINI_AI_MODEL=gemini-2.5-flash
DEEP_SEEK_AI_API_KEY=
DEEP_SEEK_AI_BASE_URL=https://api.deepseek.com
DEEP_SEEK_AI_MODEL=deepseek-v4-flash
OPENAI_API_KEY=
AI_CHAT_MODEL=gpt-4o-mini
