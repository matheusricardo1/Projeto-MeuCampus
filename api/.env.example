PORT=3001
REDIS_URL=redis://127.0.0.1:6379/0
FRONTEND_ORIGIN=http://localhost:3000,https://your-app.vercel.app,https://*.vercel.app
ECAMPUS_JWT_SECRET=replace-with-another-long-random-secret
ECAMPUS_JWT_EXPIRES_IN=2h
# Must match the same value used by workers/ecampus — encrypts/decrypts cached academic data in Redis
ECAMPUS_CACHE_ENCRYPTION_KEY=replace-with-a-long-random-secret
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX_REQUESTS=10
LOGIN_RATE_LIMIT_WINDOW_MS=60000

# Postgres - stores plan/payment records keyed by a one-way HMAC of the CPF (never the raw CPF)
DATABASE_URL=postgresql://user:password@localhost:5432/ufamacademics

# Mercado Pago - PIX + card (credit/debit) checkout for the paid plan
MERCADOPAGO_ACCESS_TOKEN=replace-with-your-mercadopago-access-token
# Public key (safe to expose client-side) - used by the Card Payment Brick to tokenize cards in-browser/in-webview
MERCADOPAGO_PUBLIC_KEY=replace-with-your-mercadopago-public-key
MERCADOPAGO_WEBHOOK_SECRET=replace-with-your-mercadopago-webhook-secret
# Optional: public HTTPS URL Mercado Pago calls to notify payment status changes (in addition to polling)
MERCADOPAGO_WEBHOOK_URL=https://your-api.example.com/billing/webhook/mercadopago

# AI daily message quotas
AI_FREE_DAILY_LIMIT=6
AI_PAID_DAILY_LIMIT=100
