generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PAID
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// Categories shared by students in the Comunidade tab, grouped in the app into
/// sections (Mercado, Divulgação, Oportunidades, Ajudar a comunidade). The board
/// is one table; per-category structured fields live in CommunityPost.payload.
enum CommunityCategory {
  // Ajudar a comunidade (crowdsourcing em tempo real)
  BOLSA
  ENERGIA
  FILA_RU
  // Mercado
  COMIDAS
  ALUGUEIS
  TROCAS_VENDAS
  // Divulgação
  EVENTOS
  PALESTRAS
  FORMATURAS
  ACHADOS_PERDIDOS
  // Oportunidades
  EMPREGOS
  ESTAGIO
  PESQUISA
}

/// Moderation state. Real-time crowdsourcing signals (bolsa/energia/fila RU) are
/// created already APPROVED so they stay instant; marketplace/divulgação/
/// oportunidades announcements start PENDING and only become public once an
/// admin approves them.
enum CommunityPostStatus {
  PENDING
  APPROVED
  REJECTED
}

/// id is never the raw CPF - it is HMAC-SHA256(CPF) via pseudonymousUserId(),
/// a one-way derivation. You can look up a user from a CPF, never a CPF from
/// a user id (LGPD-friendly pseudonymization, see pseudonymous-user-id.ts).
model User {
  id             String    @id
  plan           Plan      @default(FREE)
  planExpiresAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
}

model Payment {
  id                  String        @id @default(uuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  mpPaymentId          String?      @unique
  status              PaymentStatus @default(PENDING)
  amountCents         Int
  planDays            Int
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([userId])
}

/// Per-message AI token spend, captured from the LLM provider's usage
/// response. Deliberately has no FK to User — not every AI chat message maps
/// to a paying user, this just needs to be aggregatable for cost/profit math.
model AiUsage {
  id            String   @id @default(uuid())
  userId        String
  jobId         String
  provider      String
  model         String
  inputTokens   Int
  outputTokens  Int
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

/// A crowdsourced report in the Comunidade tab (bolsa caiu?, fila do RU, quedas
/// de energia). authorId is the same pseudonymous HMAC(CPF) used for User.id, so
/// ownership/dedup/moderation are server-authenticated; authorName is a display
/// snapshot sent by the client (spoofable but low-risk on a public board — see
/// the identity note in the community module). payload carries category-specific
/// fields: BOLSA { scholarship, dropped }, FILA_RU { level }, ENERGIA { location }.
model CommunityPost {
  id           String                  @id @default(uuid())
  authorId     String
  authorName   String
  category     CommunityCategory
  status       CommunityPostStatus     @default(PENDING)
  body         String
  payload      Json?
  confirmCount Int                     @default(0)
  createdAt    DateTime                @default(now())
  confirmations CommunityConfirmation[]

  @@index([status, category, createdAt])
}

/// One row per (post, user) so the same student can't inflate confirmCount by
/// confirming a report twice — keeps the crowdsourcing signal honest.
model CommunityConfirmation {
  id        String        @id @default(uuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime      @default(now())

  @@unique([postId, userId])
}

/// Browser Web Push subscriptions for the owner's admin dashboard. Not tied
/// to a User row - the owner has no student account (see admin-login
/// usecase, env-credential based) - keyed by the browser's unique push
/// endpoint so each device/browser the owner opens the dashboard in gets its
/// own row.
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
