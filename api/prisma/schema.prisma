generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PAID
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

/// id is never the raw CPF - it is HMAC-SHA256(CPF) via pseudonymousUserId(),
/// a one-way derivation. You can look up a user from a CPF, never a CPF from
/// a user id (LGPD-friendly pseudonymization, see pseudonymous-user-id.ts).
model User {
  id             String    @id
  plan           Plan      @default(FREE)
  planExpiresAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  payments       Payment[]
}

model Payment {
  id                  String        @id @default(uuid())
  userId              String
  user                User          @relation(fields: [userId], references: [id])
  mpPaymentId          String?      @unique
  status              PaymentStatus @default(PENDING)
  amountCents         Int
  planDays            Int
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([userId])
}

/// Per-message AI token spend, captured from the LLM provider's usage
/// response. Deliberately has no FK to User — not every AI chat message maps
/// to a paying user, this just needs to be aggregatable for cost/profit math.
model AiUsage {
  id            String   @id @default(uuid())
  userId        String
  jobId         String
  provider      String
  model         String
  inputTokens   Int
  outputTokens  Int
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

/// Browser Web Push subscriptions for the owner's admin dashboard. Not tied
/// to a User row - the owner has no student account (see admin-login
/// usecase, env-credential based) - keyed by the browser's unique push
/// endpoint so each device/browser the owner opens the dashboard in gets its
/// own row.
model PushSubscription {
  id        String   @id @default(uuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}
